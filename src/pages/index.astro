---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Book from '../components/Book.astro';

const entry = await getEntry('pages', 'index');
const { data, render } = entry || { data: {}, render: async () => ({ Content: () => null }) };
const { Content } = await render();

const pageTitle = "Closers Press | Bespoke, Physical Books that Bypass Gatekeepers";
---

<Layout title={pageTitle}>
	<main class="text-[#292524] selection:bg-[#FF7F49]/20">
		
        {/* Split Layout Container */}
        <div class="md:flex md:flex-row relative items-start">
            
            {/* Left Column - Sticky Book */}
            <div class="md:w-1/2 md:h-screen md:sticky md:top-0 flex items-center justify-center bg-[#F4F0EB] z-10 p-6 order-1 md:order-1">
                <Book 
                    coverDiffuse="/img/briq-cover.png"
                    height={600}
                />
            </div>

            {/* Right Column - Scrollable Content */}
            <div class="md:w-1/2 bg-[#F4F0EB] order-2 md:order-2">
                
                {/* Hero Text */}
                <div class="px-6 pt-10 pb-24 md:pt-16 md:pb-32 space-y-10 animate-fade-in-up text-left max-w-xl mx-auto md:mx-0 md:pl-12">
                    <span class="text-[#FF7F49] font-serif text-2xl italic block mb-4">
                        The Art of Access
                    </span>
                    <h1 class="font-serif text-5xl md:text-7xl font-light leading-tight tracking-tight text-[#313131]">
                        Your Best Prospect Has 847 Unread Emails, And Zero Books.
                    </h1>
                    <p class="text-xl md:text-2xl text-[#57534e] font-sans font-light leading-relaxed">
                        Digital outreach is ignored instantly. Closers Press engineers bespoke, physical storybooks that bypass gatekeepers and live permanently on the desks of your highest-value prospects.
                    </p>
                    <div class="pt-8">
                        <a href="#apply" class="inline-block bg-[#1c1917] text-white rounded-[20px] px-10 py-5 uppercase text-[0.8rem] tracking-[1.5px] font-light transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 hover:bg-black">
                            Apply for a Strategy Session
                        </a>
                    </div>
                </div>

                {/* Why Smart Founders... (The Psychology) */}
                <div class="px-6 py-24 space-y-12 max-w-xl mx-auto md:mx-0 md:pl-12 border-t border-stone-200">
                    <div>
                        <span class="text-[#FF7F49] font-serif text-2xl italic block mb-4">The Psychology</span>
                        <h2 class="font-serif text-4xl md:text-5xl text-[#313131] font-light leading-tight mb-8">Why Smart Founders Are Abandoning the Inbox.</h2>
                        <p class="text-[#44403c] text-lg font-light leading-relaxed font-sans mb-8">
                            If you send a cold email to a Fortune 500 VP, it takes them 3 seconds to delete it. If you send them a cheap piece of direct mail, it goes into the lobby trash can.
                        </p>
                        <p class="text-[#44403c] text-lg font-light leading-relaxed font-sans">
                            But human psychology makes it incredibly difficult to throw away a beautifully bound, hardcover book—especially one that tells a story about <strong>their</strong> business. It doesn't go in the trash. It stays on the desk.
                        </p>
                    </div>
                </div>

                {/* Free Real Estate */}
                <div class="px-6 py-24 max-w-xl mx-auto md:mx-0 md:pl-12 border-t border-stone-200">
                     <div class="space-y-8">
                        <h2 class="font-serif text-4xl md:text-5xl text-[#313131] font-light leading-tight">Free Real Estate <br/> in the C-Suite.</h2>
                        <div class="w-16 h-[1px] bg-[#FF7F49]"></div>
                        <p class="text-[#44403c] text-lg font-light leading-relaxed font-sans">
                            We recently engineered a bespoke book campaign targeting a highly guarded executive. We bypassed the gatekeeper, and the book landed on his desk. 
                        </p>
                        <p class="text-[#44403c] text-lg font-light leading-relaxed font-sans">
                             He didn't call us that week. Or that month. He reached out <strong>six months later.</strong> Why? 
                        </p>
                        <p class="text-[#44403c] text-lg font-light leading-relaxed font-sans">
                             The book sat on his desk for 180 days. It acted as a permanent, physical billboard inside his office.
                        </p> 
						<p class="text-[#44403c] text-lg font-light leading-relaxed font-sans">
                             Try getting a 6-month shelf-life out of a LinkedIn DM.
                        </p>
                    </div>
                </div>

                {/* Methodology (Production Slot) */}
                <div class="px-6 py-24 max-w-xl mx-auto md:mx-0 md:pl-12 border-t border-stone-200">
                     <div class="space-y-8">
                        <h2 class="font-serif text-4xl md:text-5xl text-[#313131] font-light leading-tight">Secure Your Production Slot <br/> in the C-Suite.</h2>
                        <div class="w-16 h-[1px] bg-[#FF7F49]"></div>
                        <p class="text-[#44403c] text-lg font-light leading-relaxed font-sans">
                            Closers Press is an Account-Based Sniper strategy, not a volume play. Because every book is written, designed, and bound from scratch, our monthly production capacity is strictly capped.
                            </p>
                        <p class="text-[#44403c] text-lg font-light leading-relaxed font-sans">
                             We partner with B2B teams where closing just one or two enterprise accounts yields a massive return on investment.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {/* Stacked Layout Below */}
        
        {/* FAQ Section */}
        <section class="py-24 bg-white border-y border-stone-200">
            <div class="container mx-auto px-6 max-w-3xl">
                <h2 class="font-serif text-4xl md:text-5xl text-[#313131] font-light text-center mb-16">Frequently Asked Questions</h2>
                
                <div class="space-y-4">
                    {/* FAQ Item 1 */}
                    <details class="group bg-[#F4F0EB] rounded-xl overflow-hidden transition-all duration-300">
                        <summary class="flex justify-between items-center font-serif text-xl cursor-pointer list-none p-6 text-[#313131] hover:bg-[#EBE9E4] transition-colors">
                            <span>What is the minimum engagement?</span>
                            <span class="transition group-open:rotate-180">
                                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                            </span>
                        </summary>
                        <div class="text-[#57534e] font-sans font-light leading-relaxed p-6 pt-0 animate-fade-in-up">
                            We typically work with clients aiming to close deals valued at $50k+ ACV. Our campaigns are designed for quality, not quantity. We focus on high-impact, account-based marketing where a single conversion yields significant ROI.
                        </div>
                    </details>

                    {/* FAQ Item 2 */}
                    <details class="group bg-[#F4F0EB] rounded-xl overflow-hidden transition-all duration-300">
                        <summary class="flex justify-between items-center font-serif text-xl cursor-pointer list-none p-6 text-[#313131] hover:bg-[#EBE9E4] transition-colors">
                            <span>Do I need to write the book myself?</span>
                            <span class="transition group-open:rotate-180">
                                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                            </span>
                        </summary>
                        <div class="text-[#57534e] font-sans font-light leading-relaxed p-6 pt-0 animate-fade-in-up">
                            No. Our team of editorial-grade ghostwriters interviews you to extract your expertise and crafts the narrative. We handle the entire production process from concept to manuscript to design.
                        </div>
                    </details>

                    {/* FAQ Item 3 */}
                    <details class="group bg-[#F4F0EB] rounded-xl overflow-hidden transition-all duration-300">
                        <summary class="flex justify-between items-center font-serif text-xl cursor-pointer list-none p-6 text-[#313131] hover:bg-[#EBE9E4] transition-colors">
                            <span>How long does the process take?</span>
                            <span class="transition group-open:rotate-180">
                                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                            </span>
                        </summary>
                        <div class="text-[#57534e] font-sans font-light leading-relaxed p-6 pt-0 animate-fade-in-up">
                            From strategy to delivery, a typical campaign takes 6-8 weeks. This includes the strategy session, writing, design, printing, and delivery logistics.
                        </div>
                    </details>

                    {/* FAQ Item 4 */}
                    <details class="group bg-[#F4F0EB] rounded-xl overflow-hidden transition-all duration-300">
                        <summary class="flex justify-between items-center font-serif text-xl cursor-pointer list-none p-6 text-[#313131] hover:bg-[#EBE9E4] transition-colors">
                            <span>How do you ensure delivery?</span>
                            <span class="transition group-open:rotate-180">
                                <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                            </span>
                        </summary>
                        <div class="text-[#57534e] font-sans font-light leading-relaxed p-6 pt-0 animate-fade-in-up">
                            We use proprietary investigative methods to verify delivery addresses for C-Suite executives, ensuring 100% deliverability. We track every package and provide confirmation upon receipt.
                        </div>
                    </details>
                </div>
            </div>
        </section>

		{/* CTA / Multi-Step Qualification Form Area */}
		<section id="apply" class="py-32 bg-[#EBE9E4] border-t border-stone-200">
			<div class="container mx-auto px-6 max-w-2xl">
                <div class="text-center mb-16">
				    <h2 class="font-serif text-4xl md:text-5xl mb-6 text-[#313131] font-light tracking-tight">Campaign Strategy Session</h2>
				    <p class="text-stone-500 font-sans font-light">Complete the qualification form below to begin.</p>
                </div>
                
                {/* Multi-Step Form */}
                <div class="bg-white border border-stone-200 rounded-2xl p-8 md:p-12 shadow-[0_8px_30px_rgb(0,0,0,0.03)] overflow-hidden relative min-h-[400px]">
                    <form id="qualification-form" name="qualification" method="POST" data-netlify="true" class="space-y-8">
                        <input type="hidden" name="form-name" value="qualification" />
                        
                        {/* Step 1: The Basics */}
                        <div class="form-step active" data-step="1">
                            <label class="block text-[#313131] font-light font-serif text-2xl mb-8">What is your name and the URL of your company?</label>
                            <input type="text" name="name_url" required placeholder="Full Name | company.com" class="w-full border-b border-stone-300 py-4 focus:border-[#FF7F49] outline-none font-sans font-light text-xl bg-transparent transition-colors" />
                        </div>

                        {/* Step 2: The Math */}
                        <div class="form-step hidden" data-step="2">
                            <label class="block text-[#313131] font-light font-serif text-2xl mb-8">What is the Average Contract Value (ACV) of a closed enterprise deal for you?</label>
                            <select name="acv" required class="w-full border-b border-stone-300 py-4 focus:border-[#FF7F49] outline-none font-sans font-light text-xl bg-transparent transition-colors appearance-none">
                                <option value="" disabled selected>Select Value</option>
                                <option value="under-10k">Under $10k</option>
                                <option value="10k-50k">$10k - $50k</option>
                                <option value="50k-100k">$50k - $100k</option>
                                <option value="100k-plus">$100k+</option>
                            </select>
                        </div>

                        {/* Step 3: The Bottleneck */}
                        <div class="form-step hidden" data-step="3">
                            <label class="block text-[#313131] font-light font-serif text-2xl mb-8">Who is your exact target buyer, and why is your current outbound failing?</label>
                            <textarea name="target_failing" rows="3" required placeholder="e.g. VP of Sales at Fintech companies..." class="w-full border-b border-stone-300 py-4 focus:border-[#FF7F49] outline-none font-sans font-light text-xl bg-transparent transition-colors resize-none"></textarea>
                        </div>

                        {/* Step 4: The Dream Scenario */}
                        <div class="form-step hidden" data-step="4">
                            <label class="block text-[#313131] font-light font-serif text-2xl mb-8">If you could drop a Trojan Horse on the desk of 3 specific 'whale' accounts, who would they be?</label>
                            <textarea name="whale_accounts" rows="3" required placeholder="1. Google, 2. Stripe, 3. Acme..." class="w-full border-b border-stone-300 py-4 focus:border-[#FF7F49] outline-none font-sans font-light text-xl bg-transparent transition-colors resize-none"></textarea>
                        </div>

                        {/* Step 5: The Pitch */}
                        <div class="form-step hidden" data-step="5">
                            <label class="block text-[#313131] font-light font-serif text-2xl mb-8">Why is your product a perfect fit for a Closers Press bespoke campaign?</label>
                            <textarea name="why_fit" rows="3" required placeholder="Tell us why we should partner with you..." class="w-full border-b border-stone-300 py-4 focus:border-[#FF7F49] outline-none font-sans font-light text-xl bg-transparent transition-colors resize-none"></textarea>
                        </div>

                        {/* Form Navigation */}
                        <div class="flex items-center justify-between pt-12">
                            <div class="text-stone-400 text-sm font-sans">
                                Step <span id="current-step-display">1</span> of 5
                            </div>
                            <button type="button" id="next-btn" class="bg-[#1c1917] text-white rounded-full px-10 py-4 uppercase text-[0.8rem] tracking-[1px] font-medium transition-all hover:bg-black">
                                Next Step
                            </button>
                            <button type="submit" id="submit-btn" class="hidden bg-[#1c1917] text-white rounded-full px-10 py-4 uppercase text-[0.8rem] tracking-[1px] font-medium transition-all hover:bg-black">
                                Submit Application
                            </button>
                        </div>
                    </form>
                </div>
			</div>
		</section>

	</main>
</Layout>

<script>
    const form = document.getElementById('qualification-form') as HTMLFormElement;
    const nextBtn = document.getElementById('next-btn');
    const submitBtn = document.getElementById('submit-btn');
    const stepDisplay = document.getElementById('current-step-display');
    const steps = document.querySelectorAll('.form-step');
    let currentStep = 1;

    nextBtn?.addEventListener('click', () => {
        const currentStepEl = document.querySelector(`.form-step[data-step="${currentStep}"]`);
        const input = currentStepEl?.querySelector('input, select, textarea') as HTMLInputElement;

        if (input && !input.checkValidity()) {
            input.reportValidity();
            return;
        }

        if (currentStep < 5) {
            currentStepEl?.classList.add('hidden');
            currentStep++;
            const nextStepEl = document.querySelector(`.form-step[data-step="${currentStep}"]`);
            nextStepEl?.classList.remove('hidden');
            nextStepEl?.classList.add('animate-fade-in-up');
            
            if (stepDisplay) stepDisplay.textContent = currentStep.toString();

            if (currentStep === 5) {
                nextBtn.classList.add('hidden');
                submitBtn?.classList.remove('hidden');
            }
        }
    });

    form?.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        
        fetch("/", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams(formData as any).toString(),
        })
        .then(() => {
            alert('Application submitted for review. We will contact you shortly.');
            form.reset();
            window.location.hash = '';
            location.reload();
        })
        .catch((error) => alert(error));
    });
</script>

<style>
	.animate-fade-in-up {
		animation: fadeInUp 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}
    .animate-fade-in-slow {
        animation: fadeInUp 1.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        animation-delay: 0.2s;
        opacity: 0;
    }
	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
    
    .form-step {
        transition: all 0.5s ease;
    }
    
    details > summary {
      list-style: none;
    }
    details > summary::-webkit-details-marker {
      display: none;
    }
</style>